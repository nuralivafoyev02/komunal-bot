{
  "version": 2,
  "name": "komunal-bot",
  "builds": [
    {
      "src": "src/api/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "miniapp/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "src/api/server.js"
    },
    {
      "source": "/miniapp/(.*)",
      "destination": "miniapp/$1"
    },
    {
      "source": "/",
      "destination": "miniapp/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 4 * * *"
    }
  ]
}